#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  secret-gen uuid
  secret-gen password [length] [plain|ss2022]
  secret-gen hex [bytes]
  secret-gen xray-shortid [bytes]
  secret-gen xray-reality
  secret-gen age
  secret-gen age-file <output-file>
  secret-gen wireguard
  secret-gen ssh-ed25519 <output-file> [comment]
  secret-gen proxy

Notes:
  - Commands print secrets to stdout unless a file path is explicitly required.
  - ssh-ed25519 writes <output-file> and <output-file>.pub, refusing to overwrite.
  - Keep generated private material under local/ or encrypted with sops.
USAGE
}

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "error: required command not found: $1" >&2
    echo "hint: run through 'nix run .#secret-gen -- ...' or a just secret-* command" >&2
    exit 127
  fi
}

plain_password() {
  local length="${1:-32}"
  if ! [[ "$length" =~ ^[0-9]+$ ]] || [ "$length" -lt 8 ]; then
    echo "error: password length must be an integer >= 8" >&2
    exit 2
  fi

  need openssl
  local chars
  chars=""
  while [ "${#chars}" -lt "$length" ]; do
    chars="${chars}$(openssl rand -base64 "$((length * 2))" | tr -dc 'A-Za-z0-9@#%+=:,._-')"
  done
  printf '%s\n' "${chars:0:length}"
}

ss2022_password() {
  local bytes="${1:-16}"
  if ! [[ "$bytes" =~ ^[0-9]+$ ]] || { [ "$bytes" -ne 16 ] && [ "$bytes" -ne 32 ]; }; then
    echo "error: Shadowsocks 2022 password byte count must be 16 or 32" >&2
    echo "hint: 16 bytes for 2022-blake3-aes-128-gcm, 32 bytes for 2022-blake3-aes-256-gcm" >&2
    exit 2
  fi

  need openssl
  openssl rand -base64 "$bytes"
}

rand_password() {
  local length="${1:-32}"
  local mode="${2:-plain}"

  case "$mode" in
    plain) plain_password "$length" ;;
    ss2022) ss2022_password "$length" ;;
    *)
      echo "error: unknown password mode: $mode" >&2
      echo "hint: supported modes are plain and ss2022" >&2
      exit 2
      ;;
  esac
}

rand_hex() {
  local bytes="${1:-32}"
  if ! [[ "$bytes" =~ ^[0-9]+$ ]] || [ "$bytes" -lt 1 ]; then
    echo "error: byte count must be a positive integer" >&2
    exit 2
  fi

  need openssl
  openssl rand -hex "$bytes"
}

xray_shortid() {
  local bytes="${1:-8}"
  if ! [[ "$bytes" =~ ^[0-9]+$ ]] || [ "$bytes" -lt 1 ] || [ "$bytes" -gt 8 ]; then
    echo "error: xray Reality shortId byte count must be between 1 and 8" >&2
    echo "hint: 8 bytes produces the common 16-hex-character shortId" >&2
    exit 2
  fi

  rand_hex "$bytes"
}

uuid() {
  if command -v uuidgen >/dev/null 2>&1; then
    uuidgen | tr '[:upper:]' '[:lower:]'
    return
  fi

  need openssl
  local h
  h="$(openssl rand -hex 16)"
  printf '%s-%s-%s-%s-%s\n' "${h:0:8}" "${h:8:4}" "${h:12:4}" "${h:16:4}" "${h:20:12}"
}

age_keypair() {
  need age-keygen
  age-keygen
}

age_key_file() {
  local output="${1:-}"

  if [ -z "$output" ]; then
    echo "error: missing output file" >&2
    usage >&2
    exit 2
  fi

  if [ -e "$output" ]; then
    echo "error: refusing to overwrite existing age key: $output" >&2
    exit 2
  fi

  need age-keygen
  mkdir -p "$(dirname "$output")"
  age-keygen -o "$output" >/dev/null
  chmod 600 "$output"

  printf 'age_key_file: %s\n' "$output"
  printf 'public_key:   %s\n' "$(age-keygen -y "$output")"
}

wireguard_keypair() {
  if ! command -v wg >/dev/null 2>&1; then
    echo "error: required command not found: wg" >&2
    echo "hint: on Linux, run through 'nix run .#secret-gen -- wireguard'" >&2
    echo "hint: on macOS, install wireguard-tools with Homebrew or generate this on a Linux host" >&2
    exit 127
  fi

  local private public
  private="$(wg genkey)"
  public="$(printf '%s' "$private" | wg pubkey)"

  printf 'private: %s\n' "$private"
  printf 'public:  %s\n' "$public"
}

xray_reality_keypair() {
  need xray
  xray x25519
}

ssh_ed25519() {
  local output="${1:-}"
  local comment="${2:-wayjam@host}"

  if [ -z "$output" ]; then
    echo "error: missing output file" >&2
    usage >&2
    exit 2
  fi

  if [ -e "$output" ] || [ -e "$output.pub" ]; then
    echo "error: refusing to overwrite existing key: $output" >&2
    exit 2
  fi

  need ssh-keygen
  mkdir -p "$(dirname "$output")"
  ssh-keygen -q -t ed25519 -a 100 -N "" -C "$comment" -f "$output"
  chmod 600 "$output"

  printf 'private_key_file: %s\n' "$output"
  printf 'public_key_file:  %s.pub\n' "$output"
  printf 'public_key:       %s\n' "$(cat "$output.pub")"
}

proxy_bundle() {
  printf 'xray_uuid: %s\n' "$(uuid)"
  printf 'xray_ss2022_password: %s\n' "$(ss2022_password 16)"
  printf 'hy2_password: %s\n' "$(rand_password 32)"
  printf 'xray_short_id: %s\n' "$(xray_shortid 8)"
  if command -v xray >/dev/null 2>&1; then
    xray_reality_keypair
  else
    printf '%s\n' "xray binary not found; run just secret-xray-reality inside nix develop when needed."
  fi
}

command="${1:-}"
shift || true

case "$command" in
  uuid) uuid "$@" ;;
  password) rand_password "$@" ;;
  hex) rand_hex "$@" ;;
  xray-shortid) xray_shortid "$@" ;;
  xray-reality) xray_reality_keypair "$@" ;;
  age) age_keypair "$@" ;;
  age-file) age_key_file "$@" ;;
  wireguard) wireguard_keypair "$@" ;;
  ssh-ed25519) ssh_ed25519 "$@" ;;
  proxy) proxy_bundle "$@" ;;
  -h|--help|help|"") usage ;;
  *)
    echo "error: unknown command: $command" >&2
    usage >&2
    exit 2
    ;;
esac
